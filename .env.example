# Database
# Database — use @db:5432 inside Compose; for host-run API/pytest use localhost:5433
DATABASE_URL=postgresql://postgres:postgres@db:5432/neighborhoodiq
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/neighborhoodiq

# Redis
REDIS_URL=redis://redis:6379

# Claude AI
ANTHROPIC_API_KEY=

# Mapbox — server geocoding (secret sk.* token; never use NEXT_PUBLIC_ prefix)
MAPBOX_TOKEN=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side API URL inside Docker Compose (web container → api service). Optional locally.
# API_INTERNAL_URL=http://api:8000
# Mapbox — client map tiles + Places suggestions (addresses + Discover city/place search)
# Public pk.* token; URL-restrict in Mapbox dashboard. Used by report maps and /discover.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Auth.js — required for sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# FastAPI JWT signing (Bearer tokens for /api/v1). Use a long random string in real deploys.
# Same generator as AUTH_SECRET is fine; do not commit real values.
SECRET_KEY=

# Azure Storage (PDF exports)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=reports

# External Data APIs — workers (local Docker Compose --profile workers)
# EPA AQS: https://aqs.epa.gov/data/api/signup (required for worker-epa)
EPA_AQS_EMAIL=
EPA_AQS_KEY=
# FBI CDE (worker-fbi) — required for safety phase. https://api.data.gov/signup/
# Optional: FBI_CDE_MAX_AGENCY_DISTANCE_MILES, FBI_CDE_CHART_OFFENSES (must include HOM),
# FBI_CDE_CHART_BASE. See specs/002-data-ingestion-workers/research.md §8.
FBI_API_KEY=
FBI_CDE_API_KEY=
# Census ACS (worker-acs) — recommended for quota; public key from api.census.gov
CENSUS_API_KEY=
# BLS Public Data API v2 (worker-bls) — optional registration key
BLS_API_KEY=
# Workers inside Compose use DATABASE_URL with host @db:5432 (set above).
# Default scope: 10 canonical fixture counties (workers/ingest/fixtures/).
# Optional: restrict to a subset (comma-separated SSCCC FIPS), e.g. smoke test:
# INGEST_COUNTY_ALLOWLIST=05007
# Unset/empty = all fixture counties (metro) or all batch counties (national).
# National (50 states + DC): see specs/003-national-ingest/quickstart.md
# INGEST_SCOPE=metro_10
# INGEST_SCOPE=smoke
# INGEST_SCOPE=national
# INGEST_STATE_BATCH=44          # required for national worker runs (state FIPS)
# INGEST_GEO_LOAD_ALL=1          # geo worker only: load all 50+DC into geo_counties
# Orchestrator (ACA niq-worker-orchestrate / Actions "National ingest"):
# ORCH_MAX_STATE_UNITS=5
# ORCH_STATE_FILTER=44
# ORCH_FORCE_STATES=25           # re-run full pipeline for these states (bypass skip-done)
# ORCH_STATE_EXCLUDE=01,02,06    # skip these FIPS; next gap states fill max_states (force overrides)
# INGEST_FORCE=1                 # set by orchestrator on workers when forcing
# INGEST_STATUS_EVERY_N=15       # mid-job Workbook snapshot every N counties/LEAIDs
# AZURE_RESOURCE_GROUP=neighborhoodiq-rg
# AZURE_SUBSCRIPTION_ID=...
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# Environment scoring: EPA AQS primary; Open-Meteo modeled US AQI fallback at score time
# Open-Meteo (scoring environment fallback — public API, no key):
# OPEN_METEO_TIMEOUT=15
# OPEN_METEO_BATCH_SIZE=25
# OPEN_METEO_MAX_WORKERS=2
# SCORE_COUNTY_CHUNK=20
# (no OPEN_METEO_* key required for the public air-quality API).
# FEMA NRI (worker-fema) and CMS Timely (worker-cms-timely): public APIs, no keys.
# INGEST_SCOPE must be smoke or metro_10 only (national is refused for these workers).


# App
ENVIRONMENT=development
LOG_LEVEL=INFO
# Must match workers/ingest/fixtures/constants.py DATA_VINTAGE for live reports.
# Also used by API Redis report cache keys (report:{SCORE_DATA_VINTAGE}:{address_id}).
SCORE_DATA_VINTAGE=2026-Q3
